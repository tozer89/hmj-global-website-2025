# Core site / Supabase
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
SUPABASE_MANAGEMENT_ACCESS_TOKEN=YOUR_SUPABASE_MANAGEMENT_ACCESS_TOKEN

# Canonical public URLs
HMJ_CANONICAL_SITE_URL=https://hmjg.netlify.app
HMJ_CANDIDATE_PORTAL_SITE_URL=https://hmjg.netlify.app

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_CANDIDATE_MATCH_MODEL=gpt-4.1-mini
OPENAI_CANDIDATE_MATCH_FALLBACK_MODEL=gpt-5-mini
OPENAI_CREDIT_LIMIT_STATEMENT_MODEL=gpt-4.1-mini
OPENAI_CREDIT_LIMIT_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_JOB_SPEC_MODEL=gpt-5-mini
OPENAI_JOB_SEO_MODEL=gpt-5-mini

# Candidate matcher / uploads
CANDIDATE_MATCH_UPLOAD_BUCKET=candidate-matcher-uploads
CANDIDATE_DOC_SIGNED_URL_TTL_SECONDS=3600

# Candidate / auth mail delivery
RESEND_API_KEY=YOUR_RESEND_API_KEY
TASK_REMINDER_FROM_EMAIL=info@hmj-global.com
TASK_REMINDER_REPLY_TO=info@hmj-global.com
TASK_REMINDER_CRON_SECRET=YOUR_TASK_REMINDER_CRON_SECRET

# Team Tasks calendar integration
TEAM_TASKS_CALENDAR_STATE_SECRET=YOUR_TEAM_TASKS_CALENDAR_STATE_SECRET

# Optional identity / analytics salts
HMJ_IDENTITY_BASE=https://hmjg.netlify.app/.netlify/identity
ANALYTICS_IP_SALT=YOUR_ANALYTICS_IP_SALT
